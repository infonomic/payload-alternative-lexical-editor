{
  "name": "@infonomic/next",
  "version": "1.6.3",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rimraf .next .turbo node_modules",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev -H 0.0.0.0 -p 3000 --turbo",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev -H 0.0.0.0 -p 3000",
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=4096\" next build",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "lint": "biome check --write --unsafe --diagnostic-level=error",
    "ci": "payload migrate && pnpm build",
    "generate:types": "payload generate:types",
    "generate:schema": "payload-graphql generate:schema",
    "generate:importmap": "payload generate:importmap",
    "test:e2e": "playwright test",
    "test:e2e:prod": "cross-env E2E_MODE=prod playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "engines": {
    "node": "^18.20.2 || >=20.6.0"
  },
  "dependencies": {
    "@infonomic/payload-alternative-lexical-editor": "workspace:*",
    "@payloadcms/db-mongodb": "^3.84.1",
    "@payloadcms/db-postgres": "^3.84.1",
    "@payloadcms/next": "^3.84.1",
    "@payloadcms/translations": "^3.84.1",
    "@payloadcms/ui": "^3.84.1",
    "classnames": "^2.5.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.3.0",
    "graphql": "^16.14.0",
    "json-schema": "^0.4.0",
    "lexical": "^0.44.0",
    "next": "^16.2.6",
    "payload": "^3.84.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-error-boundary": "^6.1.1",
    "sharp": "^0.34.5",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@playwright/test": "^1.60.0",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "19.2.3",
    "dotenv": "^17.4.2",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3"
  }
}
